{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/notification-wrapper.sh'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/pre-push-gate.sh'"
          },
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/require-issue-link.sh'"
          },
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/ddb-readonly-gate.sh'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); runtime=$(command -v bun 2>/dev/null || command -v node 2>/dev/null); src=$([[ $(basename \"$runtime\") == bun ]] && echo src/index.ts || echo dist/index.js); exec \"$runtime\" \"${plugin_dir}${src}\"'"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "notion@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "language": "Korean",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "autoCompact": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754195027959
  }
}
