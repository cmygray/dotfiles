{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "FIGMA_TOKEN": "__REDACTED__",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/notification-wrapper.sh'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/log-english-prompt.sh'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/pre-push-gate.sh'"
          },
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/require-issue-link.sh'"
          },
          {
            "type": "command",
            "command": "sh -c '$HOME/dotfiles/claude/hooks/ddb-readonly-gate.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "codex@openai-codex": true,
    "plannotator@plannotator": true,
    "dev@superct": true,
    "ralph-loop@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "superct": {
      "source": {
        "source": "github",
        "repo": "classtinginc/super-ct"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "language": "Korean",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "autoCompact": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754195027959
  }
}
