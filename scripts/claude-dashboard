#!/usr/bin/env bash
# Claude Agent Dashboard — monitors all Claude Code panes in Zellij
set -uo pipefail

REFRESH=2
CURSOR=0

# Colors
BOLD="\033[1m"
DIM="\033[2m"
RESET="\033[0m"
CYAN="\033[36m"
YELLOW="\033[33m"
INV="\033[7m"
CLR="\033[K"

# Column widths (computed dynamically per render based on data)
W_NUM=3
W_ST=2

PANE_COUNT=0
TAB_NAMES=()
PROJECTS=()
CWDS=()
STATUSES=()
TMPDIR_DASH=$(mktemp -d)

# Terminal setup — guard stty for non-tty
ORIG_STTY=""
if [[ -t 0 ]]; then
  ORIG_STTY=$(stty -g 2>/dev/null || true)
  stty -echo -icanon min 0 time 0 2>/dev/null || true
fi

cleanup() {
  [[ -n "$ORIG_STTY" ]] && stty "$ORIG_STTY" 2>/dev/null
  printf "\033[?25h\033[J"
  rm -rf "$TMPDIR_DASH"
  exit 0
}
trap cleanup INT TERM EXIT

printf "\033[?25l"
clear

# Display width: pure bash, no subshells
# CJK chars are 3+ bytes in UTF-8 → 2 columns, ASCII → 1 column
_dw=0  # result stored here to avoid subshell
display_width() {
  local str="$1" chars=${#1}
  local lc_all_bak="${LC_ALL:-}" && LC_ALL=C
  local bytes=${#1}
  LC_ALL="$lc_all_bak"
  _dw=$(( chars + (bytes - chars) / 2 ))
}

trunc() {
  local str="$1" max="$2"
  display_width "$str"
  if [[ $_dw -le $max ]]; then
    printf '%s' "$str"
    return
  fi
  # Estimate cut point from ratio, then adjust
  local chars=${#str}
  local cut=$(( (max - 1) * chars / (_dw + 1) ))
  [[ $cut -ge $chars ]] && cut=$((chars - 1))
  display_width "${str:0:$cut}"
  while [[ $_dw -gt $((max - 1)) && $cut -gt 0 ]]; do
    cut=$((cut - 1))
    display_width "${str:0:$cut}"
  done
  printf '%s…' "${str:0:$cut}"
}

pad() {
  local str="$1" width="$2"
  display_width "$str"
  local padding=$((width - _dw))
  printf '%s' "$str"
  [[ $padding -gt 0 ]] && printf "%${padding}s" ""
}

# Build a set of CWDs with running claude processes
declare -A RUNNING_CWDS=()
build_running_set() {
  RUNNING_CWDS=()
  local pids
  pids=$(ps -eo pid=,command= 2>/dev/null \
    | grep -E '(^|/| )claude ' \
    | grep -v 'grep\|statusline\|fzf\|dashboard\|snapshot' \
    | awk '{print $1}') || true
  for pid in $pids; do
    local cwd
    cwd=$(lsof -p "$pid" -Fn 2>/dev/null | awk '/^n\//{print substr($0,2); exit}') || true
    [[ -n "$cwd" ]] && RUNNING_CWDS["$cwd"]=1
  done
}

# Parse dump-layout KDL to find tabs with command="claude" panes
fetch_data() {
  local layout
  layout=$(zellij action dump-layout 2>/dev/null) || return

  PANE_COUNT=0
  TAB_NAMES=()
  PROJECTS=()
  CWDS=()
  STATUSES=()

  # Extract base cwd from layout root
  local base_cwd=""
  base_cwd=$(echo "$layout" | sed -n 's/^[[:space:]]*cwd "\(.*\)"/\1/p' | head -1)

  build_running_set

  local cur_tab="" in_claude=0 claude_cwd=""
  local depth=0

  while IFS= read -r line; do
    local opens="${line//[^\{]/}"
    local closes="${line//[^\}]/}"

    # Only match real tabs at depth 1 (direct children of layout{})
    if [[ $depth -eq 1 && "$line" =~ ^[[:space:]]*tab[[:space:]] ]]; then
      # Emit previous tab if it had claude
      if [[ -n "$cur_tab" && $in_claude -eq 1 ]]; then
        _emit_entry "$cur_tab" "$claude_cwd" "$base_cwd"
      fi
      cur_tab=""
      in_claude=0
      claude_cwd=""
      if [[ "$line" =~ name=\"([^\"]+)\" ]]; then
        cur_tab="${BASH_REMATCH[1]}"
      fi
    fi

    # Inside a tab, detect claude pane
    if [[ -n "$cur_tab" && "$line" =~ command=\"claude\" ]]; then
      in_claude=1
      if [[ "$line" =~ cwd=\"([^\"]+)\" ]]; then
        claude_cwd="${BASH_REMATCH[1]}"
      fi
    fi

    depth=$(( depth + ${#opens} - ${#closes} ))
  done <<< "$layout"

  # Handle last tab
  if [[ -n "$cur_tab" && $in_claude -eq 1 ]]; then
    _emit_entry "$cur_tab" "$claude_cwd" "$base_cwd"
  fi
}

_emit_entry() {
  local tab="$1" cwd="$2" base="$3"
  local full_cwd="$cwd"
  [[ -n "$full_cwd" && "$full_cwd" != /* ]] && full_cwd="$base/$full_cwd"
  [[ -z "$full_cwd" ]] && full_cwd="$base"

  TAB_NAMES+=("$tab")
  CWDS+=("$full_cwd")
  PROJECTS+=("$(basename "$full_cwd" 2>/dev/null || echo "?")")

  if [[ -n "${RUNNING_CWDS[$full_cwd]+_}" ]]; then
    STATUSES+=("⚡")
  else
    STATUSES+=("⏸")
  fi
  PANE_COUNT=$((PANE_COUNT + 1))
}

render() {
  if [[ $PANE_COUNT -gt 0 && $CURSOR -ge $PANE_COUNT ]]; then
    CURSOR=$((PANE_COUNT - 1))
  fi

  # Compute column widths from actual data
  local W_TAB=3 W_PRJ=7  # minimum: header text length
  for i in $(seq 0 $((PANE_COUNT - 1))); do
    local len
    len=${#TAB_NAMES[$i]}; [[ $len -gt $W_TAB ]] && W_TAB=$len
    len=${#PROJECTS[$i]};  [[ $len -gt $W_PRJ ]] && W_PRJ=$len
  done
  # Add padding
  W_TAB=$((W_TAB + 2))
  W_PRJ=$((W_PRJ + 2))

  local cols
  cols=$(stty size 2>/dev/null | awk '{print $2}')
  [[ -z "$cols" || "$cols" -le 0 ]] 2>/dev/null && cols=${COLUMNS:-0}
  [[ "$cols" -le 0 ]] 2>/dev/null && cols=$(tput cols 2>/dev/null || echo 120)
  [[ "$cols" -le 0 ]] 2>/dev/null && cols=120

  printf "\033[H"
  printf "${BOLD}${CYAN} Claude Agent Dashboard${RESET}${DIM}  j/k: nav  enter: focus  1-9: jump  q: quit${RESET}${CLR}\n"
  printf "${DIM} %-${W_NUM}s ${BOLD}%-${W_TAB}s %-${W_PRJ}s %-${W_ST}s${RESET}${CLR}\n" \
    "#" "TAB" "PROJECT" "ST"

  for i in $(seq 0 $((PANE_COUNT - 1))); do
    local t_tab t_prj
    t_tab=$(trunc "${TAB_NAMES[$i]}" $W_TAB)
    t_prj=$(trunc "${PROJECTS[$i]}" $W_PRJ)
    local num=$((i + 1))

    if [[ $i -eq $CURSOR ]]; then
      printf "${INV} %-${W_NUM}s $(pad "$t_tab" $W_TAB) $(pad "$t_prj" $W_PRJ) %-${W_ST}s${RESET}${CLR}\n" \
        "$num" "${STATUSES[$i]}"
    else
      printf " ${YELLOW}%-${W_NUM}s${RESET} $(pad "$t_tab" $W_TAB) $(pad "$t_prj" $W_PRJ) %-${W_ST}s${RESET}${CLR}\n" \
        "$num" "${STATUSES[$i]}"
    fi
  done

  if [[ $PANE_COUNT -eq 0 ]]; then
    printf " ${DIM}(no Claude panes found)${RESET}${CLR}\n"
  fi

  printf "\033[J"
}

drain_input() {
  local delta=0 action=""
  while true; do
    local ch=""
    read -rsn1 -t 0.01 ch 2>/dev/null || true
    [[ -z "$ch" ]] && break
    case "$ch" in
      j) delta=$((delta + 1)) ;;
      k) delta=$((delta - 1)) ;;
      "") action="focus" ;;
      [1-9]) action="jump:$ch" ;;
      q) action="quit" ;;
      $'\x1b')
        local seq=""
        read -rsn2 -t 0.01 seq 2>/dev/null || true
        case "$seq" in
          '[A') delta=$((delta - 1)) ;;
          '[B') delta=$((delta + 1)) ;;
        esac
        ;;
    esac
  done

  if [[ $PANE_COUNT -gt 0 && $delta -ne 0 ]]; then
    CURSOR=$(( (CURSOR + delta % PANE_COUNT + PANE_COUNT) % PANE_COUNT ))
  fi

  echo "$action"
}

focus_tab() {
  local idx=$1
  if [[ $idx -ge 0 && $idx -lt ${#TAB_NAMES[@]} ]]; then
    zellij action go-to-tab-name "${TAB_NAMES[$idx]}" 2>/dev/null
  fi
}

# Process a single key, set ACTION global
handle_key() {
  ACTION=""
  local key="$1"
  case "$key" in
    j) [[ $PANE_COUNT -gt 0 ]] && CURSOR=$(( (CURSOR + 1) % PANE_COUNT )) ;;
    k) [[ $PANE_COUNT -gt 0 ]] && CURSOR=$(( (CURSOR - 1 + PANE_COUNT) % PANE_COUNT )) ;;
    "") ACTION="focus" ;;
    [1-9]) ACTION="jump:$key" ;;
    q) cleanup ;;
    $'\x1b')
      seq=""
      read -rsn2 -t 0.1 seq 2>/dev/null || true
      case "$seq" in
        '[A') [[ $PANE_COUNT -gt 0 ]] && CURSOR=$(( (CURSOR - 1 + PANE_COUNT) % PANE_COUNT )) ;;
        '[B') [[ $PANE_COUNT -gt 0 ]] && CURSOR=$(( (CURSOR + 1) % PANE_COUNT )) ;;
      esac
      ;;
  esac
}

# Input loop: handle keys instantly without re-fetching data
process_input() {
  while true; do
    key=""
    if read -rsn1 -t "$REFRESH" key 2>/dev/null; then
      handle_key "$key"

      # Drain queued keys (drain_input modifies CURSOR directly too)
      drain_action=$(drain_input)
      [[ -n "$drain_action" ]] && ACTION="$drain_action"

      case "$ACTION" in
        focus) focus_tab "$CURSOR" ;;
        jump:*) focus_tab $(( ${ACTION#jump:} - 1 )) ;;
        quit) cleanup ;;
      esac

      render
    else
      return
    fi
  done
}

# Main loop
while true; do
  fetch_data
  render
  process_input
done
