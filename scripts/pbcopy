#!/bin/sh
# pbcopy wrapper - OSC 52 clipboard sync for remote sessions (SSH + Zellij)
#
# Sends clipboard content via OSC 52 escape sequence so the client terminal
# (e.g. Ghostty) can capture it, even over SSH through Zellij.
# Also forwards to the real pbcopy when available (local clipboard).

tmp=$(mktemp "${TMPDIR:-/tmp}/pbcopy.XXXXXX") || exit 1
trap 'rm -f "$tmp"' EXIT HUP INT TERM
cat > "$tmp" || exit 1

# Local system clipboard (macOS)
if [ -x /usr/bin/pbcopy ]; then
    /usr/bin/pbcopy < "$tmp"
fi

# OSC 52: sync to client terminal clipboard
encoded=$(base64 < "$tmp" | tr -d '\n')
{ printf '\033]52;c;%s\a' "$encoded" > /dev/tty; } 2>/dev/null || true
