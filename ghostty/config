font-family = JetBrainsMono NF
font-family = JetBrains Mono
font-size = 12

# JetBrains Mono에 없는 원문자/괄호숫자 글리프를 보조 폰트로 매핑.
#
# 원문자(①~⑳ ⓐ~ⓩ Ⓐ~Ⓩ ❶~❿ ➀~➉ ➊~➓)는 EAW=Ambiguous/Neutral이라 ghostty가
# 셀 1칸만 줌. D2Coding의 원문자는 전각(2칸) 글리프라 1칸에 욱여넣으면 ghostty가
# 축소 렌더 → 너무 작아 식별 불가 (ghostty 일반 동작, issue #1903 / discussion #5588).
# 해결: 모든 글리프를 narrow(0.5em)로 그리는 IosevkaTerm Nerd Font Mono로 매핑 →
#       1칸에 딱 맞아 축소 없이 또렷. U+2460-24FF, U+2776-2793 전 범위 커버.
# U+2460-24FF: Enclosed Alphanumerics, U+2776-2793: Dingbat circled (검은/산세리프)
font-codepoint-map = U+2460-U+24FF=IosevkaTerm Nerd Font Mono
font-codepoint-map = U+2776-U+2793=IosevkaTerm Nerd Font Mono
# U+3200-32FF: Enclosed CJK Letters and Months (㈀ ㉠ ㊀) — EAW=Wide(2칸)라 전각 D2Coding이 맞음
font-codepoint-map = U+3200-U+32FF=D2Coding
macos-option-as-alt = true
copy-on-select = clipboard
unfocused-split-opacity = 0.5

# Keep SSH sessions usable on hosts that do not have xterm-ghostty terminfo.
# Avoid automatic remote terminfo installation; use env compatibility only.
shell-integration-features = ssh-env

keybind = alt+enter=ignore
keybind = super+n=new_window
keybind = super+shift+t=new_tab
keybind = super+alt+h=previous_tab
keybind = super+alt+l=next_tab

# Split navigation (performable: pass through to zellij when no Ghostty split)
keybind = performable:alt+h=goto_split:left
keybind = performable:alt+j=goto_split:down
keybind = performable:alt+k=goto_split:up
keybind = performable:alt+l=goto_split:right

# Zoom current split (mirrors wezterm TogglePaneZoomState)
keybind = ctrl+shift+z=toggle_split_zoom

# Copy URL under cursor (partial stand-in for wezterm ctrl+shift+space quick-select; URL-only)
keybind = ctrl+shift+space=copy_url_to_clipboard
# DIAG: alternate binding to test whether ctrl+shift+space is being swallowed by macOS
keybind = super+shift+u=copy_url_to_clipboard

# Leader: ctrl+'
keybind = ctrl+apostrophe>r=new_split:right
keybind = ctrl+apostrophe>d=new_split:down
keybind = ctrl+apostrophe>shift+t=previous_tab
keybind = ctrl+apostrophe>t=next_tab
keybind = ctrl+apostrophe>shift+comma=move_tab:-1
keybind = ctrl+apostrophe>shift+period=move_tab:1
keybind = ctrl+apostrophe>x=close_surface

keybind = ctrl+apostrophe>1=move_tab:0
keybind = ctrl+apostrophe>2=move_tab:1
keybind = ctrl+apostrophe>3=move_tab:2
keybind = ctrl+apostrophe>4=move_tab:3
keybind = ctrl+apostrophe>5=move_tab:4
keybind = ctrl+apostrophe>6=move_tab:5
keybind = ctrl+apostrophe>7=move_tab:6
keybind = ctrl+apostrophe>8=move_tab:7
keybind = ctrl+apostrophe>9=move_tab:8
